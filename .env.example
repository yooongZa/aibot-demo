GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional: Chainlit auth (turn on to require login)
# AUTH_ENABLED=1
# AUTH_USERS=admin:changeme,demo:demo
# CHAINLIT_AUTH_SECRET=run `chainlit create-secret` and paste the output here

# Optional: Literal AI cloud observability (https://literalai.com)
# LITERAL_API_KEY=your_literal_api_key
